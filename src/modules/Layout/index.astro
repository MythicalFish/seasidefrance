---
import '@styles/global.css';
import '@styles/lodgify.css';
import '@styles/colors.css';
import '@vscode/codicons/dist/codicon.css';
import '@fontsource-variable/montserrat';
import '@fontsource-variable/open-sans';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const defaultTitle = 'Chateau Stays in France';
const defaultDescription =
  'Discover luxury vacation rentals and stay at the beautiful Chateau de Rochebonne in France. Experience authentic French hospitality with stunning seaside locations.';
const defaultOgImage = '/thumbnails/280268.jpg';
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://seasidefrance.com';

const {
  title = defaultTitle,
  description = defaultDescription,
  canonical,
  ogImage = defaultOgImage,
  noIndex = false,
  structuredData,
} = Astro.props;

const pageTitle = `Seaside France - ${title}`;
const canonicalUrl = canonical ?? (Astro.url ? new URL(Astro.url.pathname, siteOrigin).toString() : siteOrigin);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteOrigin).toString();
const robots = noIndex ? 'noindex, nofollow' : 'index, follow';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>{pageTitle}</title>
    <!-- Google Tag Manager -->
    <script>
      (function (
        w: Window & { [key: string]: Array<Record<string, unknown>> },
        d: Document,
        s: string,
        l: string,
        i: string
      ) {
        const windowWithDataLayer = w;
        windowWithDataLayer[l] = windowWithDataLayer[l] || [];
        windowWithDataLayer[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        const f = d.getElementsByTagName(s)[0] as HTMLScriptElement | undefined;
        const j = d.createElement(s) as HTMLScriptElement;
        const dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        if (f?.parentNode) {
          f.parentNode.insertBefore(j, f);
        }
      })(
        window as unknown as Window & { [key: string]: Array<Record<string, unknown>> },
        document,
        'script',
        'dataLayer',
        'GTM-P66JJ5J8'
      );
    </script>
    <!-- End Google Tag Manager -->
    <meta
      name="description"
      content={description}
    />
    <meta name="author" content="Seaside France" />
    <meta name="robots" content={robots} />
    <meta name="language" content="English" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Seaside France" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="geo.region" content="FR" />
    <meta name="geo.country" content="France" />
    <link rel="canonical" href={canonicalUrl} />
    {
      structuredData && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
    <link rel="icon" href="/favicon-light.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon-dark.png" media="(prefers-color-scheme: light)" />
  </head>
  <body class="bg-white min-h-screen">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-P66JJ5J8"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />
  </body>
</html>
