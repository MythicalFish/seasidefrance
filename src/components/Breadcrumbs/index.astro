---
export interface BreadcrumbItem {
  label: string;
  href: string;
}

export interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<nav aria-label="Breadcrumb" class:list={['text-sm text-slate-600', className]}>
  <ol class="m-0 flex list-none flex-wrap items-center gap-2 p-0">
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;

        return (
          <li class="flex items-center gap-2">
            {isLast ? (
              <span aria-current="page" class="font-semibold text-slate-900">
                {item.label}
              </span>
            ) : (
              <a class="text-[#056c8f] underline-offset-2 hover:underline" href={item.href}>
                {item.label}
              </a>
            )}
            {!isLast && <span aria-hidden="true">/</span>}
          </li>
        );
      })
    }
  </ol>
</nav>
