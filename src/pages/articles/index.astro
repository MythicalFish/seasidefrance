---
import { getCollection } from 'astro:content';
import Layout from '@modules/Layout/index.astro';
import SiteHeader from '@modules/Layout/SiteHeader';
import Box from '@components/Box/index.astro';
import Breadcrumbs from '@components/Breadcrumbs/index.astro';
import { buildBreadcrumbStructuredData } from '@lib/seo';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const breadcrumbItems = [
  { label: 'Home', href: 'https://seasidefrance.com/' },
  { label: 'Travel Articles', href: 'https://seasidefrance.com/articles' },
];

const articleItems = articles.map((article, index) => {
  const href = `/articles/${article.slug}/`;
  const url = `https://seasidefrance.com${href}`;

  return {
    article,
    href,
    url,
    position: index + 1,
  };
});

const collectionPageStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Seaside France Travel Articles',
  description:
    'Local travel guides and practical planning tips for Charente-Maritime family holidays.',
  url: 'https://seasidefrance.com/articles',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: articleItems.map(({ article, position, url }) => ({
      '@type': 'ListItem',
      position,
      url,
      item: {
        '@type': 'Article',
        headline: article.data.title,
        description: article.data.description,
        datePublished: article.data.publishDate.toISOString(),
        dateModified: (article.data.updatedDate || article.data.publishDate).toISOString(),
      },
    })),
  },
};

const structuredData = [
  collectionPageStructuredData,
  buildBreadcrumbStructuredData(breadcrumbItems),
];
---

<Layout
  title="Charente-Maritime Travel Articles"
  description="Read practical guides, local tips, and itineraries for planning your Seaside France holiday."
  canonical="https://seasidefrance.com/articles"
  structuredData={structuredData}
>
  <SiteHeader client:load />
  <main class="container py-8 md:py-14">
    <Box class="max-w-5xl">
      <Breadcrumbs items={breadcrumbItems} class="mb-4" />
      <div class="prose max-w-3xl">
        <h1>Travel Articles</h1>
        <p>
          Browse local guidance for planning your stay in Charente-Maritime, from beach
          recommendations to family-friendly itineraries.
        </p>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2 not-prose">
        {
          articleItems.map(({ article, href, url }) => (
            <article class="flex h-full flex-col rounded-3xl border border-slate-200 bg-slate-50 p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:bg-white">
              <div class="flex items-center gap-3 text-sm text-slate-600">
                <time datetime={article.data.publishDate.toISOString()}>
                  {article.data.publishDate.toLocaleDateString('en-GB', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric',
                  })}
                </time>
                {article.data.updatedDate &&
                  article.data.updatedDate > article.data.publishDate && (
                    <span aria-label="Article has been updated">
                      Updated {article.data.updatedDate.toLocaleDateString('en-GB')}
                    </span>
                  )}
              </div>
              <h2 class="mt-4 text-2xl font-semibold text-slate-900">
                <a class="no-underline hover:underline" href={href}>
                  {article.data.title}
                </a>
              </h2>
              <p class="mt-3 text-base leading-7 text-slate-700">{article.data.description}</p>
              {article.data.tags.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-2" aria-label="Article topics">
                  {article.data.tags.map((tag) => (
                    <li class="rounded-full bg-white px-3 py-1 text-sm text-slate-700 ring-1 ring-slate-200">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
              <div class="mt-6 pt-2">
                <a
                  class="font-semibold text-sky-800 no-underline hover:text-sky-900 hover:underline"
                  href={href}
                >
                  Read article →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </Box>
  </main>
</Layout>
