---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '@modules/Layout/index.astro';
import SiteHeader from '@modules/Layout/SiteHeader';
import Box from '@components/Box/index.astro';
import Breadcrumbs from '@components/Breadcrumbs/index.astro';
import { buildBreadcrumbStructuredData } from '@lib/seo';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props as { article: CollectionEntry<'articles'> };
const { Content } = await render(article);

const canonical = `https://seasidefrance.com/articles/${article.slug}/`;
const ogImage = article.data.heroImage || '/thumbnails/280268.jpg';
const faqItems = article.data.faq || [];
const breadcrumbItems = [
  { label: 'Home', href: 'https://seasidefrance.com/' },
  { label: 'Travel Articles', href: 'https://seasidefrance.com/articles' },
  { label: article.data.title, href: canonical },
];
const articleStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  image: [ogImage],
  datePublished: article.data.publishDate.toISOString(),
  dateModified: (article.data.updatedDate || article.data.publishDate).toISOString(),
  author: {
    '@type': 'Organization',
    name: article.data.author,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
};
const faqStructuredData =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: faq.answer,
          },
        })),
      }
    : null;
const structuredData = [
  articleStructuredData,
  buildBreadcrumbStructuredData(breadcrumbItems),
  ...(faqStructuredData ? [faqStructuredData] : []),
];

const articleCtaLinks = [
  {
    href: '/discover',
    title: 'Browse holiday rentals',
    description:
      'See family-friendly gites and château stays close to the beaches and villages mentioned in this guide.',
  },
  {
    href: '/contact',
    title: 'Ask us about your trip',
    description:
      'Get practical help choosing the best stay, timing your visit, or planning around local family activities.',
  },
  {
    href: '/articles',
    title: 'Read more local guides',
    description:
      'Explore more Seaside France articles for beaches, itineraries, and practical Charente-Maritime tips.',
  },
];
---

<Layout
  title={article.data.title}
  description={article.data.description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  article={{
    author: article.data.author,
    publishedTime: article.data.publishDate.toISOString(),
    modifiedTime: (article.data.updatedDate || article.data.publishDate).toISOString(),
    tags: article.data.tags,
  }}
  structuredData={structuredData}
>
  <SiteHeader client:load />
  <main class="container py-8 md:py-14">
    <Box class="prose max-w-4xl">
      <Breadcrumbs items={breadcrumbItems} class="mb-4 not-prose" />
      <h1>{article.data.title}</h1>
      <p class="text-sm opacity-70">
        Published {article.data.publishDate.toLocaleDateString('en-GB')} by {article.data.author}
      </p>
      <Content />
      {
        faqItems.length > 0 && (
          <section
            aria-labelledby="article-faqs"
            class="mt-10 border-t border-slate-200 pt-8 not-prose"
          >
            <h2 id="article-faqs" class="mb-6 text-2xl font-semibold text-slate-900">
              Frequently asked questions
            </h2>
            <div class="space-y-6">
              {faqItems.map((faq) => (
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                  <h3 class="m-0 text-lg font-semibold text-slate-900">{faq.question}</h3>
                  <p class="mb-0 mt-3 text-base leading-7 text-slate-700">{faq.answer}</p>
                </div>
              ))}
            </div>
          </section>
        )
      }
      <aside
        aria-labelledby="plan-your-stay"
        class="mt-10 rounded-3xl border border-sky-100 bg-sky-50/70 p-6 not-prose"
      >
        <div class="max-w-2xl">
          <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-sky-800">
            Plan your stay
          </p>
          <h2 id="plan-your-stay" class="m-0 text-2xl font-semibold text-slate-900">
            Turn this guide into a Charente-Maritime holiday plan
          </h2>
          <p class="mb-0 mt-3 text-base leading-7 text-slate-700">
            Use these next steps to move from inspiration to booking and keep exploring the region.
          </p>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {
            articleCtaLinks.map((link) => (
              <a
                href={link.href}
                class="flex h-full flex-col rounded-2xl border border-white/80 bg-white p-5 text-slate-900 no-underline shadow-sm transition hover:-translate-y-0.5 hover:border-sky-200 hover:text-slate-950 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-700"
              >
                <span class="text-lg font-semibold text-slate-900">{link.title}</span>
                <span class="mt-2 text-sm leading-6 text-slate-700">{link.description}</span>
                <span class="mt-4 font-semibold text-sky-800">Explore →</span>
              </a>
            ))
          }
        </div>
      </aside>
    </Box>
  </main>
</Layout>
